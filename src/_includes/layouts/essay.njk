---
layout: layouts/base.njk
---
{%- set dateDisplay = date | pldate if lang == "pl" else date | endate -%}
{%- set readingLabel = (readingTime | string) + " minut czytania" if lang == "pl" else (readingTime | string) + " min read" -%}
{%- set pairLabel = "Read in English →" if lang == "pl" else "Czytaj po polsku →" -%}
{%- set listenLabel = ("Posłuchaj — " + (readingTime | string) + " min · głos autora") if lang == "pl" else ("Listen — " + (readingTime | string) + " min · author's voice") -%}
{%- set subscribeTitle = "Nowe eseje co dwa tygodnie" if lang == "pl" else "New essays every two weeks" -%}
{%- set subscribeBody = "Bez spamu — tylko kolejny esej, prosto do skrzynki. Po polsku lub po angielsku, jak wolisz." if lang == "pl" else "No spam — just the next essay, straight to your inbox. In Polish or English, your choice." -%}
{%- set subscribeCta = "Subskrybuj newsletter" if lang == "pl" else "Subscribe to the newsletter" -%}

<div class="essay-head">
  <h1>{{ title }}</h1>
  <div class="meta">
    <time datetime="{{ date | isodate }}">{{ dateDisplay }}</time> · {{ readingLabel }}{% if pair %} · <a class="gesture-link" href="{{ pair }}">{{ pairLabel }}{% gesture "underline", 120, 10 %}</a>{% endif %}
  </div>
</div>

{%- if audio %}
<div class="player" hidden>
  <button type="button" class="play" aria-label="{{ 'Odtwórz' if lang == 'pl' else 'Play' }}">▶</button>
  <input type="range" class="bar" value="0" min="0" step="0.1">
  <span class="time">0:00</span>
  <audio preload="none" controls src="{{ audio }}"></audio>
</div>
<noscript>
  <p>{{ listenLabel }}: <audio preload="none" controls src="{{ audio }}"></audio></p>
</noscript>
<p class="essay-meta">{{ listenLabel }}</p>
{%- endif %}

<figure class="hero-ill">
  <span class="only-light">{% heroimg "src/assets/ill/light/" + heroLight + ".jpg", heroAlt %}</span>
  <span class="only-dark">{% heroimg "src/assets/ill/dark/" + heroDark + ".jpg", heroAlt %}</span>
</figure>

<article>
  {{ content | safe | replace("<blockquote>", '<blockquote class="pull">') }}
</article>

<div class="monogram-zone">
  <span class="only-light stamp" data-awake>{% img "src/assets/ill/light/ill-monogram-220.jpg", "Monogram AP", [220], false, "monogram" %}</span>
  <span class="only-dark stamp" data-awake>{% img "src/assets/ill/dark/dill-monogram-220.jpg", "Monogram AP", [220], false, "monogram" %}</span>
  <span class="bird" data-awake aria-hidden="true"></span>
</div>

{%- if site.links.substack %}
<div class="subscribe">
  <h2>{{ subscribeTitle }}</h2>
  <p>{{ subscribeBody }}</p>
  <a class="btn" href="{{ site.links.substack }}">
    <span class="flourish">{% gesture "frame", 240, 60 %}</span>
    {{ subscribeCta }}
  </a>
</div>
{%- endif %}
