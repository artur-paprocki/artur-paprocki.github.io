---
permalink: /en/feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.author }}</title>
  <subtitle>Essays on the future of creativity.</subtitle>
  <link href="{{ site.url }}/en/feed.xml" rel="self"/>
  <link href="{{ site.url }}/en/"/>
  <id>{{ site.url }}/en/</id>
  <updated>{{ (collections.essays_en | published | first).data.date | isodate }}T00:00:00Z</updated>
  {%- for essay in collections.essays_en | published %}
  <entry>
    <title>{{ essay.data.title }}</title>
    <link href="{{ site.url }}{{ essay.url }}"/>
    <id>{{ site.url }}{{ essay.url }}</id>
    <published>{{ essay.data.date | isodate }}T00:00:00Z</published>
    <updated>{{ essay.data.date | isodate }}T00:00:00Z</updated>
    <author><name>{{ site.author }}</name></author>
    <summary>{{ essay.data.description }}</summary>
  </entry>
  {%- endfor %}
</feed>
